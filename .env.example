# Live Traffic Dashboard (Singapore) — Environment Template
# Copy this file to `.env` and fill in values for local development.
# Do NOT commit `.env` to version control.

# ---------------------------------------------------------------------
# data.gov.sg API
# ---------------------------------------------------------------------
# The traffic-images endpoint is public — a key is only used for
# increased rate limits. Leave commented to run without one.
DATA_GOV_SG_API_BASE=https://api.data.gov.sg/v1
DATA_GOV_SG_API_KEY=

# ---------------------------------------------------------------------
# Proxy server
# ---------------------------------------------------------------------
# Host + port the Express proxy listens on. Defaults to loopback only.
# Use 0.0.0.0 to bind every interface, or a specific LAN/Tailscale IP.
SERVER_HOST=127.0.0.1
SERVER_PORT=3001
# Server-side cache TTL for upstream responses (ms).
# Keep at/above 30s to avoid hammering the upstream API.
PROXY_CACHE_TTL_MS=30000

# ---------------------------------------------------------------------
# Client dev server (Vite)
# ---------------------------------------------------------------------
# Host + port the Vite dev server binds to. Loopback by default.
CLIENT_HOST=127.0.0.1
CLIENT_PORT=8501
# Comma-separated extra hostnames/IPs allowed to load the dev server.
# Useful if you also bind to a LAN/Tailscale IP for mobile access.
# CLIENT_ALLOWED_HOSTS=
