# Live Traffic Dashboard (Singapore) — Environment Template
# Copy this file to `.env` and fill in values for local development.
# Do NOT commit `.env` to version control.

# ---------------------------------------------------------------------
# data.gov.sg API
# ---------------------------------------------------------------------
# The traffic-images endpoint is public — a key is only used for
# increased rate limits. Leave commented to run without one.
DATA_GOV_SG_API_BASE=https://api.data.gov.sg/v1
# DATA_GOV_SG_API_KEY=

# ---------------------------------------------------------------------
# Proxy server
# ---------------------------------------------------------------------
# Host + port the Express proxy listens on. Defaults to the Tailscale IP
# (100.72.108.26) so it's reachable from other devices on the tailnet.
# Use 127.0.0.1 for loopback-only, or 0.0.0.0 to bind every interface.
SERVER_HOST=100.72.108.26
SERVER_PORT=3000
# Server-side cache TTL for upstream responses (ms).
# Keep at/above 30s to avoid hammering the upstream API.
PROXY_CACHE_TTL_MS=30000

# ---------------------------------------------------------------------
# Client dev server (Vite)
# ---------------------------------------------------------------------
# Host + port the Vite dev server binds to. Same Tailscale IP default
# as the proxy so the UI is reachable from your phone / other devices.
CLIENT_HOST=100.72.108.26
CLIENT_PORT=8501
# Comma-separated extra hostnames/IPs allowed to load the dev server.
# Useful for LAN / Tailscale access from mobile. Example:
# CLIENT_ALLOWED_HOSTS=100.72.108.26,my-laptop.tail-scale.ts.net
# CLIENT_ALLOWED_HOSTS=
